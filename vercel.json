{
  "version": 2,
  "public": true,
  "regions": ["fra1"],
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "www.plusrent.md" }],
      "destination": "https://plusrent.md/",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.plusrent.md" }],
      "destination": "https://plusrent.md/:path*",
      "permanent": true
    },
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/ro/",             "destination": "/ro/index.html" },
    { "source": "/ru/",             "destination": "/ru/index.html" },
    { "source": "/en/",             "destination": "/en/index.html" },
    { "source": "/ro",              "destination": "/ro/index.html" },
    { "source": "/ru",              "destination": "/ru/index.html" },
    { "source": "/en",              "destination": "/en/index.html" },
    { "source": "/ro/sofer-treaz",  "destination": "/ro/sofer-treaz.html" },
    { "source": "/ru/sofer-treaz",  "destination": "/ru/sofer-treaz.html" },
    { "source": "/en/sofer-treaz",  "destination": "/en/sofer-treaz.html" },
    { "source": "/ro/cars",         "destination": "/ro/cars.html" },
    { "source": "/ru/cars",         "destination": "/cars.html" },
    { "source": "/en/cars",         "destination": "/cars.html" },
    { "source": "/ro/about",        "destination": "/about.html" },
    { "source": "/ru/about",        "destination": "/about.html" },
    { "source": "/en/about",        "destination": "/about.html" },
    { "source": "/ro/contact",      "destination": "/contact.html" },
    { "source": "/ru/contact",      "destination": "/contact.html" },
    { "source": "/en/contact",      "destination": "/contact.html" },
    { "source": "/cars",            "destination": "/cars.html" },
    { "source": "/car-single",      "destination": "/car-single.html" },
    { "source": "/login",           "destination": "/login.html" },
    { "source": "/account-dashboard","destination": "/account-dashboard.html" },
    { "source": "/about",           "destination": "/about.html" },
    { "source": "/contact",         "destination": "/contact.html" },
    { "source": "/sofer-treaz",     "destination": "/sofer-treaz.html" },
    { "source": "/all-codes",       "destination": "/all-codes.html" },
    { "source": "/terms",           "destination": "/terms.html" },
    { "source": "/spinning-wheel-standalone.html", "destination": "/spinning-wheel-standalone.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "env": { "NODE_ENV": "production" },
  "build": { "env": { "NODE_ENV": "production" } }
}
